{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "jsx": "react-jsx",
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "esModuleInterop": true,
        "moduleResolution": "node",
        "skipLibCheck": true,
        "target": "ES6",
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"],
            "@/src/*": ["./src/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
    "exclude": ["node_modules"]
}
